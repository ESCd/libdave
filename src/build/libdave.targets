<Project>

  <PropertyGroup>
    <!-- NOTE: disable static linking if no runtime identifier is specified -->
    <LibDaveEnableStaticLinking Condition=" '$(RuntimeIdentifier)' == '' ">false</LibDaveEnableStaticLinking>

    <!-- NOTE: enable static linking if AOT publishing is enabled and a runtime identifier is specified -->
    <LibDaveEnableStaticLinking Condition=" '$(LibDaveEnableStaticLinking)' == '' AND '$(PublishAot)' == 'true' AND '$(RuntimeIdentifier)' != '' ">true</LibDaveEnableStaticLinking>

    <!-- NOTE: disable runtime linking if static linking is enabled -->
    <LibDaveEnableRuntimeLinking Condition=" '$(LibDaveEnableStaticLinking)' == 'true' ">false</LibDaveEnableRuntimeLinking>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(LibDaveEnableStaticLinking)' == 'true' AND '$(LibDaveLinkerArgs)' == '' AND '$(RuntimeIdentifier)' != '' ">
    <LibDaveLinkerArgs Condition=" $(RuntimeIdentifier.StartsWith('linux')) ">-Wl,--push-state,-Bstatic,-lstdc++,-lgcc,--pop-state</LibDaveLinkerArgs>
    <LibDaveLinkerArgs Condition=" $(RuntimeIdentifier.StartsWith('osx')) ">-lc++</LibDaveLinkerArgs>
  </PropertyGroup>

  <ItemGroup Condition=" '$(LibDaveEnableRuntimeLinking)' == 'true' ">
    <Content Include="$(LibDaveDirectory)\shared\**\*.*" Visible="$(LibDaveItemsVisible)" Condition=" '$(RuntimeIdentifier)' == '' ">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Link>runtimes\%(RecursiveDir)\%(Filename)%(Extension)</Link>
      <TargetPath>runtimes\%(RecursiveDir)\%(Filename)%(Extension)</TargetPath>
    </Content>

    <Content Include="$(LibDaveDirectory)\shared\$(RuntimeIdentifier)\native\*.*" Visible="$(LibDaveItemsVisible)" Condition=" '$(RuntimeIdentifier)' != '' ">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Link>%(Filename)%(Extension)</Link>
      <TargetPath>%(Filename)%(Extension)</TargetPath>
    </Content>
  </ItemGroup>

  <ItemGroup Condition=" '$(LibDaveEnableStaticLinking)' == 'true' AND '$(RuntimeIdentifier)' != '' ">
    <DirectPInvoke Include="dave;libdave" />

    <!-- <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\*.*" /> -->

    <!-- NOTE: ordering matters -->
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libdave.*" />
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libhpke.*" />
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libmlspp.*" />
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libmls_ds.*" />
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libmls_vectors.*" />
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libtls_syntax.*" />
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libbytes.*" />
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libssl.*" />
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libcrypto.*" />

    <LinkerArg Include="$(LibDaveLinkerArgs)" Condition=" '$(LibDaveLinkerArgs)' != '' " />
  </ItemGroup>

</Project>