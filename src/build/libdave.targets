<Project>

  <PropertyGroup>
    <!-- NOTE: disable static linking if no runtime identifier is specified -->
    <LibDaveStaticLinking Condition=" '$(RuntimeIdentifier)' == '' ">false</LibDaveStaticLinking>

    <!-- NOTE: enable static linking if AOT publishing is enabled and a runtime identifier is specified -->
    <LibDaveStaticLinking Condition=" '$(LibDaveStaticLinking)' == 'none' AND '$(PublishAot)' == 'true' AND '$(RuntimeIdentifier)' != '' ">true</LibDaveStaticLinking>

    <!-- NOTE: disable runtime linking if static linking is enabled -->
    <LibDaveRuntimeLinking Condition=" '$(LibDaveStaticLinking)' == 'true' ">false</LibDaveRuntimeLinking>
  </PropertyGroup>

  <ItemGroup Condition=" '$(LibDaveRuntimeLinking)' == 'true' ">
    <Content Include="$(LibDaveDirectory)\shared\**\*.*" Visible="$(LibDaveItemsVisible)" Condition=" '$(Configuration)' == 'Debug' OR '$(RuntimeIdentifier)' == '' ">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Link>runtimes\%(RecursiveDir)\%(Filename)%(Extension)</Link>
      <TargetPath>runtimes\%(RecursiveDir)\%(Filename)%(Extension)</TargetPath>
    </Content>

    <Content Include="$(LibDaveDirectory)\shared\$(RuntimeIdentifier)\native\*.*" Visible="$(LibDaveItemsVisible)" Condition=" '$(RuntimeIdentifier)' != '' ">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Link>%(Filename)%(Extension)</Link>
      <TargetPath>%(Filename)%(Extension)</TargetPath>
    </Content>
  </ItemGroup>

  <PropertyGroup Condition=" '$(LibDaveStaticLinking)' == 'true' ">
    <LinkStandardCPlusPlusLibrary Condition=" $([MSBuild]::IsOSPlatform('Linux')) OR $([MSBuild]::IsOSPlatform('OSX')) ">true</LinkStandardCPlusPlusLibrary>
    <StaticOpenSslLinking>true</StaticOpenSslLinking>
  </PropertyGroup>

  <ItemGroup Condition=" '$(LibDaveStaticLinking)' == 'true' AND '$(RuntimeIdentifier)' != '' ">
    <DirectPInvoke Include="dave;libdave" />

    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libdave.*" />
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libmlspp.*" />
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libtls_syntax.*" />
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libbytes.*" />
    <NativeLibrary Include="$(LibDaveDirectory)\static\$(RuntimeIdentifier)\native\libhpke.*" />
  </ItemGroup>

  <Target Name="_PrepareLibDaveBuild" AfterTargets="PrepareForBuild">
    <Error Text="A RuntimeIdentifier must be specified when static linking is enabled." Condition=" '$(LibDaveStaticLinking)' == 'true' AND '$(RuntimeIdentifier)' == '' " />
    <Warning Text="LibDaveRuntimeLinking=true: runtime linking should not be enabled when static linking is enabled." Condition=" '$(LibDaveRuntimeLinking)' == 'true' AND '$(LibDaveStaticLinking)' == 'true' " />
  </Target>

</Project>